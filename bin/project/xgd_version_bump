#!/usr/bin/env python3
"""Project version-bump script (stub).

This is a stub generated by ``xgd init``. Fill in the bump logic for
your project below — XGD's "every commit MUST bump __version__"
convention only protects pip-install no-ops if there's a real version
to bump.

The dispatcher's dep-discovery walk (BUG-272) shells out to this script
with ``--list-paths`` to learn which files it writes; those paths get
excluded from the file-overlap dep signal. Without this exclusion,
every commit on the branch shows up as a "dependency" of every other
commit, flooding ``depends_on`` with false positives.

Required interface:

  ./bin/project/xgd_version_bump                # bump the version
  ./bin/project/xgd_version_bump --list-paths   # print paths this script writes
  ./bin/project/xgd_version_bump --help         # usage

The ``--list-paths`` mode MUST exit 0 and print one path per line
(relative to the repo root). Empty output is valid — it means "no
exclusion" (current safe over-discovery behaviour).

To customise:
  1. Set WRITTEN_PATHS to the file(s) your bump touches (e.g.
     ["package.json"], ["Cargo.toml"], ["src/version.rs"]).
  2. Implement the bump logic in ``main()`` — read the current version,
     increment, write back.
  3. Test: ./bin/project/xgd_version_bump --list-paths should print
     your file(s); a normal invocation should bump and write.

Examples (per-language):
  Python:    WRITTEN_PATHS = ["src/<package>/__init__.py"]
  Node.js:   WRITTEN_PATHS = ["package.json"]
  Rust:      WRITTEN_PATHS = ["Cargo.toml"]
  Swift:     WRITTEN_PATHS = ["Package.swift"]  (or a Version.swift constant)
  Multi:     WRITTEN_PATHS = ["pyproject.toml", "src/<package>/version.py"]
"""

from __future__ import annotations

import sys


# TODO: list the files your bump script writes. Empty list = no exclusion
# (safe default; dep discovery will be over-broad until you fill this in).
WRITTEN_PATHS: list[str] = []


_STUB_SPEC = """\
ERROR: bin/project/xgd_version_bump is a stub — version bump not implemented.

The free-coding gate (`xgd ticket move-to-free-coded`) will reject every
ticket promotion until at least one of the recorded commits contains the
correct version bump.  Implement this script before your first free-coded
commit.

Required interface:

  ./bin/project/xgd_version_bump                           # bump the version (default: patch)
  ./bin/project/xgd_version_bump --check <sha> [...] \\    # verify version bump in commits
                                  --version X.Y.Z
  ./bin/project/xgd_version_bump --list-paths              # list files written (exit 0, empty ok)
  ./bin/project/xgd_version_bump --help                    # usage

To implement:
  1. Set WRITTEN_PATHS to the file(s) your bump writes.
     (e.g. ["package.json"], ["src/__init__.py"], ["Cargo.toml"])
  2. Implement the default bump in main().
  3. Implement --check: exit 0 if any <sha> introduced version X.Y.Z
     in any of WRITTEN_PATHS (use `git show <sha>:<rel_path>`); exit 1 otherwise.
  See bin/project/xgd_version_bump in the xgd source repo for a reference.
"""


def main(argv: list[str]) -> int:
    if argv and argv[0] in ("--help", "-h"):
        print(__doc__)
        return 0

    if argv and argv[0] == "--list-paths":
        for p in WRITTEN_PATHS:
            print(p)
        return 0

    print(_STUB_SPEC)
    return 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
